# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
max_line_length = 120

[{*.yml,*.yaml}]
indent_size = 2

[{*.json,*.js,*.ts,*.tsx,*.vue,*.mjs,*.cjs}]
indent_size = 2

[{*.md,*.adoc}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
