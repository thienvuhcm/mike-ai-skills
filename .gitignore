# ── OS junk ──────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Cygwin/MSYS bash crash dumps ─────────
*.stackdump

# ── Machine-local Claude Code settings ───
# Per-machine permission allowlist + absolute paths + local-only hooks. Never share.
.claude/settings.local.json

# ── Stray OpenSpec CLI output ────────────
# Auto-generated by the `openspec` CLI when it treats this dir as a code project.
# mike-ai-skills is a knowledge/skills repo, NOT a code project — never commit these.
/openspec-*/

# ── Editor / IDE ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.tmp
*.orig

# ── Logs ─────────────────────────────────
*.log

# ── Build artifacts (safety net) ─────────
node_modules/
dist/
build/
target/
__pycache__/
*.pyc
